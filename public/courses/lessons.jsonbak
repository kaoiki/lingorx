  "eg-1": { "courseId": "english-grammar", "title": "Present Tense", "type": "grammar", "units": [
    { "type": "grammar", "prompt": "She ___ to school every day.", "answer": "goes", "options": ["go", "goes", "going"] },
    { "type": "grammar", "prompt": "I ___ coffee every morning.", "answer": "drink", "options": ["drinks", "drink", "drinking"] },
    { "type": "grammar", "prompt": "He ___ English very well.", "answer": "speaks", "options": ["speak", "speaks", "speaking"] },
    { "type": "grammar", "prompt": "They ___ in a big city.", "answer": "live", "options": ["lives", "live", "living"] },
    { "type": "grammar", "prompt": "The sun ___ in the east.", "answer": "rises", "options": ["rise", "rises", "rising"] },
    { "type": "grammar", "prompt": "My mother ___ delicious food.", "answer": "cooks", "options": ["cook", "cooks", "cooking"] },
    { "type": "grammar", "prompt": "We ___ TV after dinner.", "answer": "watch", "options": ["watch", "watches", "watching"] },
    { "type": "grammar", "prompt": "The cat ___ on the sofa.", "answer": "sleeps", "options": ["sleep", "sleeps", "sleeping"] }
  ]},
  "eg-2": { "courseId": "english-grammar", "title": "Past Tense", "type": "grammar", "units": [
    { "type": "grammar", "prompt": "I ___ a movie yesterday.", "answer": "watched", "options": ["watch", "watched", "watching"] },
    { "type": "grammar", "prompt": "She ___ to the park last Sunday.", "answer": "went", "options": ["go", "went", "gone"] },
    { "type": "grammar", "prompt": "He ___ breakfast at 7am.", "answer": "ate", "options": ["eat", "ate", "eaten"] },
    { "type": "grammar", "prompt": "They ___ a new car last month.", "answer": "bought", "options": ["buy", "bought", "buying"] },
    { "type": "grammar", "prompt": "I ___ her at the party.", "answer": "met", "options": ["meet", "met", "meeting"] },
    { "type": "grammar", "prompt": "We ___ a great time.", "answer": "had", "options": ["have", "had", "having"] },
    { "type": "grammar", "prompt": "She ___ the letter yesterday.", "answer": "wrote", "options": ["write", "wrote", "written"] },
    { "type": "grammar", "prompt": "He ___ his keys this morning.", "answer": "lost", "options": ["lose", "lost", "losing"] }
  ]},
  "eg-3": { "courseId": "english-grammar", "title": "Articles & Prepositions", "type": "grammar", "units": [
    { "type": "grammar", "prompt": "I saw ___ elephant at the zoo.", "answer": "an", "options": ["a", "an", "the"] },
    { "type": "grammar", "prompt": "She is ___ teacher.", "answer": "a", "options": ["a", "an", "the"] },
    { "type": "grammar", "prompt": "The book is ___ the table.", "answer": "on", "options": ["in", "on", "at"] },
    { "type": "grammar", "prompt": "I will meet you ___ 5pm.", "answer": "at", "options": ["in", "on", "at"] },
    { "type": "grammar", "prompt": "He lives ___ Tokyo.", "answer": "in", "options": ["in", "on", "at"] },
    { "type": "grammar", "prompt": "___ sun is very bright today.", "answer": "The", "options": ["A", "An", "The"] },
    { "type": "grammar", "prompt": "She went ___ the store.", "answer": "to", "options": ["to", "for", "at"] },
    { "type": "grammar", "prompt": "I have been here ___ Monday.", "answer": "since", "options": ["for", "since", "from"] }
  ]},
  "eg-4": { "courseId": "english-grammar", "title": "Sentence Structure", "type": "grammar", "units": [
    { "type": "grammar", "prompt": "Arrange: like / I / apples", "answer": "I like apples", "options": ["I like apples", "Apples I like", "Like I apples"] },
    { "type": "grammar", "prompt": "Arrange: is / she / a doctor", "answer": "She is a doctor", "options": ["She is a doctor", "Is she a doctor", "A doctor she is"] },
    { "type": "grammar", "prompt": "Arrange: to school / go / every day / they", "answer": "They go to school every day", "options": ["They go to school every day", "Go they to school every day", "Every day they to school go"] },
    { "type": "grammar", "prompt": "Arrange: not / like / I / coffee", "answer": "I do not like coffee", "options": ["I do not like coffee", "Not like I coffee", "I like not coffee"] },
    { "type": "grammar", "prompt": "Arrange: you / where / from / are", "answer": "Where are you from", "options": ["Where are you from", "You are from where", "From where you are"] }
  ]},

  "et-1": { "courseId": "english-translation", "title": "Daily Expressions", "type": "translation", "units": [
